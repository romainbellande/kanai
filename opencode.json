{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
        "type": "remote",
        "url": "https://mcp.context7.com/mcp"
    },
    "stitch": {
        "type": "remote",
        "url": "https://stitch.googleapis.com/mcp",
        "enabled": true,
        "headers": {
            "X-Goog-Api-Key": "{env:STITCH_API_KEY}"
        }
    },
    "openmemory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "openmemory-js",
        "mcp"
      ]
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@0.1.14"
  ]
}