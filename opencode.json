{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
        "type": "remote",
        "url": "https://mcp.context7.com/mcp"
    },
    "stitch": {
        "type": "remote",
        "url": "https://stitch.googleapis.com/mcp",
        "enabled": true,
        "headers": {
            "X-Goog-Api-Key": "{env:STITCH_API_KEY}"
        }
    },
    "obsidian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@bitbonsai/mcpvault@latest",
        ".vault"
      ]
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@0.1.14"
  ]
}